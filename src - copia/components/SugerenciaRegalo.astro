---
// SugerenciaRegalo.astro
---

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎁 SECCIÓN: SUGERENCIA DE REGALO                            -->
<!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-10 pb-12 px-6 overflow-hidden" id="seccion-regalos">

    <!-- SEPARADORES DORADOS -->
    <div class="absolute top-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-[#C2A96B]/60 to-transparent"></div>
    <div class="absolute bottom-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-[#C2A96B]/60 to-transparent"></div>

    <!-- CONTENIDO CENTRADO -->
    <div class="relative z-10 flex flex-col items-center text-center max-w-xs mx-auto">

        <!-- PLUMA SUPERIOR -->
        <div class="mb-5" id="pluma-regalos">
            <img
                src="/imagenes/pluma.png"
                alt="Pluma decorativa"
                class="w-20 sm:w-24 object-contain"
            />
        </div>

        <!-- IMAGEN REGALO -->
        <div class="mb-6" id="img-regalo">
            <img
                src="/imagenes/regalo.png"
                alt="Regalo"
                class="w-16 sm:w-20 object-contain"
                style="filter: brightness(0) saturate(100%) invert(72%) sepia(40%) saturate(400%) hue-rotate(5deg) brightness(95%);"
            />
        </div>

        <!-- TEXTO PRINCIPAL -->
        <p
            class="font-sans text-[#f3ead9] text-base sm:text-lg leading-relaxed mb-6"
            id="texto-regalo"
        >
            Tu presencia es nuestro mejor regalo, pero si deseas obsequiarnos algo, ponemos a tu disposición nuestra mesa de regalo en:
        </p>

        <!-- IMAGEN MULTICENTER -->
        <div class="mb-6 w-full" id="img-multicenter">
            <div class="border border-[#C2A96B]/60 rounded-sm px-6 py-4 flex items-center justify-center">
                <img
                    src="/imagenes/multicenter.png"
                    alt="Multicenter"
                    class="w-36 sm:w-44 object-contain"
                />
            </div>
        </div>

        <!-- BOTÓN VER UBICACIÓN -->
        <a
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-10 py-3 rounded-xl font-jane-light text-white text-base uppercase tracking-[0.2em]
                   bg-gradient-to-b from-[#e08344] to-[#c95f28]
                   border border-[#f3ead9]/20 shadow-lg
                   transition-all duration-300 hover:scale-105 active:scale-95"
            id="btn-ubicacion-regalo"
        >
            Ver Ubicación
        </a>

    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: "#seccion-regalos",
                start: "top 85%",
                toggleActions: "play none none reset",
            },
        });

        tl.fromTo(
            "#pluma-regalos",
            { opacity: 0, y: -20, scale: 0.8 },
            { opacity: 1, y: 0, scale: 1, duration: 1, ease: "power2.out" },
            0,
        )
        .fromTo(
            "#img-regalo",
            { opacity: 0, scale: 0.7 },
            { opacity: 1, scale: 1, duration: 0.8, ease: "back.out(1.4)" },
            0.2,
        )
        .fromTo(
            ["#texto-regalo", "#img-multicenter"],
            { opacity: 0, y: 20 },
            { opacity: 1, y: 0, duration: 0.9, stagger: 0.2, ease: "sine.out" },
            0.4,
        )
        .fromTo(
            "#btn-ubicacion-regalo",
            { opacity: 0, scale: 0.9 },
            { opacity: 1, scale: 1, duration: 0.8, ease: "back.out(1.4)" },
            0.8,
        );
    });
</script>
