---
// Agradecimiento.astro
---

<section class="relative w-full pt-10 pb-32 px-6 overflow-hidden" id="seccion-agradecimiento">

    <!-- FONDO: recto arriba, línea diagonal que sube abajo -->
    <div
        class="absolute inset-0 z-0 bg-[#0b2138]"
        style="clip-path: polygon(0 0, 100% 0, 100% 88%, 0 100%);"
    ></div>

    <div class="relative z-10 flex flex-col items-center text-center max-w-xs mx-auto">

        <!-- TÍTULO "Agradecimiento" -->
        <h2
            class="font-romantic-lovely text-[#d9c07a] text-5xl sm:text-6xl leading-tight mb-4"
            id="titulo-agradecimiento"
        >
            Agradecimiento
        </h2>

        <!-- PUNTO SEPARADOR -->
        <div class="w-2 h-2 rounded-full bg-[#d4682a] mb-6" id="punto-agradecimiento"></div>

        <!-- MENSAJE -->
        <p
            class="font-mollen-light text-[#f3ead9]/90 text-base sm:text-lg leading-relaxed"
            id="texto-agradecimiento"
        >
            A Dios por ser pieza fundamental en nuestro matrimonio, a nuestros padres y hermanos por ser nuestro apoyo y soporte, y a cada uno de ustedes por acompañarnos en este día tan especial con su presencia y cariño incondicional.
        </p>

        <!-- MARCO DORADO CON PADRINOS -->
        <div
            class="w-full mt-8 border-2 border-[#C2A96B] rounded-2xl px-6 py-8"
            id="marco-padrinos"
        >
            <!-- PADRINOS DE RELIGIÓN -->
            <div class="mb-6">
                <p class="font-jane-light font-bold uppercase tracking-[0.15em] text-[#d9c07a] text-base sm:text-lg mb-1">
                    Padrinos de Religión
                </p>
                <p class="font-mollen-light font-bold text-[#f3ead9]/90 text-base leading-relaxed">
                    Sof. Mtre. (SP) Renan Pardo Meneces<br />
                    Arq. Margarita Maida Arze
                </p>
            </div>

            <!-- PADRINOS DE CIVIL -->
            <div class="mb-6">
                <p class="font-jane-light font-bold uppercase tracking-[0.15em] text-[#d9c07a] text-base sm:text-lg mb-1">
                    Padrinos de Civil
                </p>
                <p class="font-mollen-light font-bold text-[#f3ead9]/90 text-base leading-relaxed">
                    Ing. Jose Antonio Orellana Ricaldez<br />
                    Prof. Romelinda Veizaga Medina
                </p>
            </div>

            <!-- PADRINOS DE ARO -->
            <div>
                <p class="font-jane-light font-bold uppercase tracking-[0.15em] text-[#d9c07a] text-base sm:text-lg mb-1">
                    Padrinos de Aro
                </p>
                <p class="font-mollen-light font-bold text-[#f3ead9]/90 text-base leading-relaxed">
                      Carlos Anguela Ojeda<br />
                  Prof. Reyna Canelas Medina
                </p>
            </div>
        </div>

    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: "#seccion-agradecimiento",
                start: "top 85%",
                toggleActions: "play none none reset",
            },
        });

        tl.fromTo(
            "#titulo-agradecimiento",
            { opacity: 0, y: -20 },
            { opacity: 1, y: 0, duration: 1, ease: "power2.out" },
            0,
        )
        .fromTo(
            "#punto-agradecimiento",
            { opacity: 0, scale: 0 },
            { opacity: 1, scale: 1, duration: 0.6, ease: "back.out(2)" },
            0.3,
        )
        .fromTo(
            "#texto-agradecimiento",
            { opacity: 0, y: 20 },
            { opacity: 1, y: 0, duration: 1, ease: "sine.out" },
            0.5,
        )
        .fromTo(
            "#marco-padrinos",
            { opacity: 0, y: 20 },
            { opacity: 1, y: 0, duration: 1, ease: "sine.out" },
            0.7,
        );
    });
</script>
