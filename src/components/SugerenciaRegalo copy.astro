---
// SugerenciaRegalo.astro
const numeroWhatsapp = "59169414806";
const mensajeWhatsapp = "Quiero ver el catálogo de regalos de Alain y Marisabel.";
const urlWhatsapp = `https://wa.me/${numeroWhatsapp}?text=${encodeURIComponent(mensajeWhatsapp)}`;
---

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎁 SECCIÓN: SUGERENCIA DE REGALO                            -->
<!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-10 pb-12 px-6 overflow-hidden" id="seccion-regalos">

    <!-- SEPARADORES DORADOS -->
    <div class="absolute top-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-[#C2A96B]/60 to-transparent"></div>
    <div class="absolute bottom-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-[#C2A96B]/60 to-transparent"></div>

    <!-- DECORACIÓN FLORAL COSTADITO2 (izquierda) -->
    <img
        src="/imagenes/costadito2.png"
        alt="Decoración floral"
        class="absolute -left-3 top-[85%] -translate-y-1/2 w-20 sm:w-24 z-20 pointer-events-none select-none"
        id="costadito2-regalos"
    />

    <!-- CONTENIDO CENTRADO -->
    <div class="relative z-10 flex flex-col items-center text-center max-w-xs mx-auto">

        <!-- PLUMA SUPERIOR -->
        <div class="mb-5" id="pluma-regalos">
            <img
                src="/imagenes/pluma.png"
                alt="Pluma decorativa"
                class="w-20 sm:w-24 object-contain"
            />
        </div>

        <!-- IMAGEN REGALO -->
        <div class="mb-6" id="img-regalo">
            <img
                src="/imagenes/regalo.png"
                alt="Regalo"
                class="w-16 sm:w-20 object-contain"
                style="filter: brightness(0) saturate(100%) invert(72%) sepia(40%) saturate(400%) hue-rotate(5deg) brightness(95%);"
            />
        </div>

        <!-- TEXTO PRINCIPAL -->
        <p
            class="font-mollen-light text-[#f3ead9]/90 text-base sm:text-lg leading-relaxed mb-6"
            id="texto-regalo"
        >
            Tu presencia es nuestro mejor regalo, pero si deseas obsequiarnos algo, ponemos a tu disposición nuestra mesa de regalo en:
        </p>

        <!-- IMAGEN MULTICENTER -->
        <div class="mb-3 w-full" id="img-multicenter">
            <div class="border border-[#C2A96B]/60 rounded-sm px-6 py-4 flex items-center justify-center">
                <img
                    src="/imagenes/multicenter.png"
                    alt="Multicenter"
                    class="w-36 sm:w-44 object-contain"
                />
            </div>
        </div>

        <!-- DIRECCIÓN -->
        <p
            class="font-mollen-light text-[#f3ead9]/90 text-base sm:text-lg leading-relaxed mb-6"
            id="direccion-regalo"
        >
            Av. Uyuni, casi puente Muyurina
        </p>

        <!-- BOTÓN VER UBICACIÓN -->
        <a
            href="https://maps.app.goo.gl/7j8NNEw8URMWDhCv7"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-10 py-3 rounded-xl font-jane-light text-white text-base uppercase tracking-[0.2em]
                   bg-gradient-to-b from-[#e08344] to-[#c95f28]
                   border border-[#f3ead9]/20 shadow-lg
                   transition-all duration-300 hover:scale-105 active:scale-95"
            id="btn-ubicacion-regalo"
        >
            Ver Ubicación
        </a>

        <!-- BOTÓN CONTACTO WHATSAPP (catálogo de regalos) -->
        <a
            href={urlWhatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 mt-4 px-10 py-3 rounded-xl font-jane-light text-white text-base uppercase tracking-[0.2em]
                   bg-gradient-to-b from-[#e08344] to-[#c95f28]
                   border border-[#f3ead9]/20 shadow-lg
                   transition-all duration-300 hover:scale-105 active:scale-95"
            id="btn-whatsapp-regalo"
            aria-label="Contactar por WhatsApp para ver el catálogo de regalos"
        >
            <svg class="w-5 h-5 text-white shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.117 1.526 5.847L.057 23.882a.5.5 0 00.606.63l6.194-1.624A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.882a9.875 9.875 0 01-5.031-1.376l-.36-.214-3.733.979.996-3.648-.235-.374A9.857 9.857 0 012.118 12C2.118 6.533 6.533 2.118 12 2.118S21.882 6.533 21.882 12 17.467 21.882 12 21.882z"/>
            </svg>
            <span>Contacto</span>
        </a>

    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: "#seccion-regalos",
                start: "top 85%",
                toggleActions: "play none none reset",
            },
        });

        tl.fromTo(
            "#pluma-regalos",
            { opacity: 0, y: -20, scale: 0.8 },
            { opacity: 1, y: 0, scale: 1, duration: 1, ease: "power2.out" },
            0,
        )
        .fromTo(
            "#img-regalo",
            { opacity: 0, scale: 0.7 },
            { opacity: 1, scale: 1, duration: 0.8, ease: "back.out(1.4)" },
            0.2,
        )
        .fromTo(
            ["#texto-regalo", "#img-multicenter", "#direccion-regalo"],
            { opacity: 0, y: 20 },
            { opacity: 1, y: 0, duration: 0.9, stagger: 0.2, ease: "sine.out" },
            0.4,
        )
        .fromTo(
            ["#btn-ubicacion-regalo", "#btn-whatsapp-regalo"],
            { opacity: 0, scale: 0.9 },
            { opacity: 1, scale: 1, duration: 0.8, stagger: 0.15, ease: "back.out(1.4)" },
            0.8,
        );
    });
</script>
