---
// NombresPadres.astro
---

<section class="relative w-full pt-4 pb-8 px-6 overflow-hidden" id="seccion-padres">

    <!-- PLUMA SUPERIOR CENTRADA -->
    <div class="flex justify-center mb-6" id="pluma-top">
        <img
            src="/imagenes/pluma.png"
            alt="Pluma decorativa"
            class="w-24 sm:w-28 object-contain"
        />
    </div>

    <!-- TÍTULO -->
    <div class="text-center mb-5 px-6" id="titulo-padres">
        <p class="font-jane-light uppercase tracking-[0.12em] text-[#f3ead9] text-lg sm:text-lg leading-snug">
            Con la bendición de Dios y nuestros padres:
        </p>

    </div>

    <!-- CONTENIDO CENTRADO CON COSTADITO A LA DERECHA -->
    <div class="relative max-w-xs mx-auto">

        <!-- COSTADITO derecha -->
        <img
            src="/imagenes/costadito.png"
            alt="Decoración floral"
            class="absolute -right-10 -top-14 w-24 sm:w-28 z-10 pointer-events-none select-none rotate-6"
            id="costadito-padres"
        />

        <!-- PADRES DEL NOVIO -->
        <div class="text-center mb-4" id="seccion-novio">
            <p class="font-jane-light text-[#d9c07a] text-lg sm:text-base tracking-[0.15em] uppercase mb-1">
                Padres del Novio
            </p>
            <p class="font-mollen-light text-[#f3ead9]/90 text-base leading-relaxed">
                Francisco Canales Medina<br />
                Norma Molina Villalta
            </p>
        </div>

        <!-- PADRES DE LA NOVIA -->
        <div class="text-center" id="seccion-novia">
            <p class="font-jane-light text-[#d9c07a] text-lg sm:text-base tracking-[0.15em] uppercase mb-1">
                Padres de la Novia
            </p>
            <p class="font-mollen-light text-[#f3ead9]/90 text-base leading-relaxed">
                Sof. Mtre. (SP) Juan José López  Fernández<br />
                Marísabel Arteaga Barriga
            </p>
        </div>

    </div>

    <!-- PADRINOS -->
    <div class="relative max-w-xs mx-auto mt-10" id="seccion-padrinos">

        <!-- PADRINOS DE ARO -->
        <div class="text-center mb-6" id="padrinos-aro">
            <p class="font-jane-light text-[#d9c07a] text-lg sm:text-base tracking-[0.15em] uppercase mb-1">
                Padrinos de Aro
            </p>
            <p class="font-mollen-light text-[#f3ead9]/90 text-base leading-relaxed">
                Prof. Reyna Canelas Medina <br />
                Carlos Anguela Ojeda
            </p>
        </div>

        <!-- PADRINOS RELIGIOSOS -->
        <div class="text-center mb-6" id="padrinos-religiosos">
            <p class="font-jane-light text-[#d9c07a] text-lg sm:text-base tracking-[0.15em] uppercase mb-1">
                Padrinos Religiosos
            </p>
            <p class="font-mollen-light text-[#f3ead9]/90 text-base leading-relaxed">
                Sof. Mtre. (SP) Renan Pardo Meneces<br />
                Arq. Margarita Maida Arze
            </p>
        </div>

        <!-- PADRINOS DE CIVIL -->
        <div class="text-center" id="padrinos-civil">
            <p class="font-jane-light text-[#d9c07a] text-lg sm:text-base tracking-[0.15em] uppercase mb-1">
                Padrinos de Civil
            </p>
            <p class="font-mollen-light text-[#f3ead9]/90 text-base leading-relaxed">
                Prof. Romelinda Veizaga Medina<br />
                Ing. Jose Antonio Orellana Ricaldez
            </p>
        </div>

    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: "#seccion-padres",
                start: "top 85%",
                toggleActions: "play none none reset",
            },
        });

        tl.fromTo(
            "#pluma-top",
            { opacity: 0, y: -30, scale: 0.8 },
            { opacity: 1, y: 0, scale: 1, duration: 1, ease: "power2.out" },
            0,
        )
        .fromTo(
            "#titulo-padres",
            { opacity: 0, y: 20 },
            { opacity: 1, y: 0, duration: 1, ease: "power2.out" },
            0.2,
        )
        .fromTo(
            "#costadito-padres",
            { opacity: 0, x: 40 },
            { opacity: 1, x: 0, duration: 1.2, ease: "power2.out" },
            0.3,
        )
        .fromTo(
            ["#seccion-novio", "#separador-padres", "#seccion-novia"],
            { opacity: 0, y: 20 },
            { opacity: 1, y: 0, duration: 0.9, stagger: 0.2, ease: "sine.out" },
            0.4,
        )
        .fromTo(
            ["#padrinos-aro", "#padrinos-religiosos", "#padrinos-civil"],
            { opacity: 0, y: 20 },
            { opacity: 1, y: 0, duration: 0.9, stagger: 0.2, ease: "sine.out" },
            0.8,
        );
    });
</script>
