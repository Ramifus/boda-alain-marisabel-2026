---
// Fotos2.astro
const fotos = [
    "/imagenes/foto1.webp",
    "/imagenes/foto2.webp",
    "/imagenes/foto3.webp",
    "/imagenes/foto4.webp",
    "/imagenes/foto5.webp",
    "/imagenes/foto6.webp",
    "/imagenes/foto7.webp",
    "/imagenes/foto8.webp",
    "/imagenes/foto9.webp",
    "/imagenes/foto10.webp",
    "/imagenes/foto11.webp",
];
---

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 📸 SECCIÓN: NOSOTROS - CARRUSEL + GALERÍA                   -->
<!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-10 pb-14 px-5 overflow-hidden" id="seccion-fotos2">

    <!-- TÍTULO -->
    <h2
        class="font-romantic-lovely text-[#d9c07a] text-5xl sm:text-6xl text-center mb-8"
        id="titulo-nosotros"
    >
        Nosotros
    </h2>

    <!-- CARRUSEL PRINCIPAL (auto-rotativo) -->
    <div class="relative w-full max-w-sm mx-auto mb-4" id="carrusel-nosotros">
        <div class="relative w-full aspect-[3/4] rounded-xl overflow-hidden shadow-2xl border border-[#C2A96B]/40">
            {
                fotos.map((foto, i) => (
                    <img
                        src={foto}
                        alt={`Foto ${i + 1}`}
                        class="carrusel-img absolute inset-0 w-full h-full object-cover transition-opacity duration-1000"
                        style={`opacity: ${i === 0 ? 1 : 0};`}
                        data-index={i}
                    />
                ))
            }
        </div>
        <!-- Puntos indicadores -->
        <div class="flex justify-center gap-1.5 mt-3" id="dots-carrusel">
            {
                fotos.map((_, i) => (
                    <span
                        class="dot-carrusel w-1.5 h-1.5 rounded-full transition-all duration-300"
                        style={`background-color: ${i === 0 ? "#d9c07a" : "rgba(217,192,122,0.3)"};`}
                        data-dot={i}
                    />
                ))
            }
        </div>
    </div>

    <!-- GALERÍA SCATTERED (con rotación) -->
    <div class="grid grid-cols-2 gap-4 max-w-md mx-auto mt-10" id="galeria-scattered">
        {
            fotos.map((foto, i) => (
                <div
                    class="galeria-item rounded-lg overflow-hidden shadow-xl border border-[#C2A96B]/30"
                    style={`transform: rotate(${i % 2 === 0 ? "-4deg" : "4deg"});`}
                    data-gindex={i}
                >
                    <img
                        src={foto}
                        alt={`Galería ${i + 1}`}
                        class="w-full aspect-[3/4] object-cover"
                        loading="lazy"
                    />
                </div>
            ))
        }
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 SCRIPT: CARRUSEL + ANIMACIONES GSAP                      -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        // ═══ CARRUSEL AUTO-ROTATIVO ═══
        const imgs = Array.from(
            document.querySelectorAll<HTMLImageElement>(".carrusel-img"),
        );
        const dots = Array.from(
            document.querySelectorAll<HTMLElement>(".dot-carrusel"),
        );
        let actual = 0;

        function mostrar(indice: number) {
            imgs.forEach((img, i) => {
                img.style.opacity = i === indice ? "1" : "0";
            });
            dots.forEach((dot, i) => {
                dot.style.backgroundColor =
                    i === indice ? "#d9c07a" : "rgba(217,192,122,0.3)";
            });
        }

        if (imgs.length > 0) {
            setInterval(() => {
                actual = (actual + 1) % imgs.length;
                mostrar(actual);
            }, 2800);
        }

        // ═══ TÍTULO ═══
        gsap.fromTo(
            "#titulo-nosotros",
            { opacity: 0, y: -20 },
            {
                opacity: 1,
                y: 0,
                duration: 1,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: "#seccion-fotos2",
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );

        // ═══ CARRUSEL ENTRADA ═══
        gsap.fromTo(
            "#carrusel-nosotros",
            { opacity: 0, scale: 0.9 },
            {
                opacity: 1,
                scale: 1,
                duration: 1.2,
                ease: "power3.out",
                scrollTrigger: {
                    trigger: "#carrusel-nosotros",
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );

        // ═══ GALERÍA: entra recto y luego rota ═══
        const items = Array.from(
            document.querySelectorAll<HTMLElement>(".galeria-item"),
        );
        items.forEach((item, i) => {
            const rot = i % 2 === 0 ? -4 : 4;
            gsap.fromTo(
                item,
                { opacity: 0, y: 40, rotation: 0, scale: 0.9 },
                {
                    opacity: 1,
                    y: 0,
                    rotation: rot,
                    scale: 1,
                    duration: 0.9,
                    ease: "back.out(1.3)",
                    scrollTrigger: {
                        trigger: item,
                        start: "top 90%",
                        toggleActions: "play none none reset",
                    },
                },
            );
        });
    });
</script>
