---
// CodigoVestimenta.astro
---

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 👔 SECCIÓN: CÓDIGO DE VESTIMENTA                            -->
<!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-2 pb-10 px-6 overflow-hidden" id="seccion-vestimenta">

    <!-- COSTADITO derecha -->
    <img
        src="/imagenes/costadito.png"
        alt="Decoración floral"
        class="absolute -right-4 top-1/2 -translate-y-1/2 w-28 sm:w-32 z-10 pointer-events-none select-none rotate-6"
        id="costadito-vestimenta"
    />

    <!-- CONTENIDO CENTRADO -->
    <div class="relative z-20 flex flex-col items-center text-center max-w-xs mx-auto">

        <!-- IMAGEN ROPA (iconos traje y vestido) -->
        <div class="mb-6" id="img-vestimenta">
            <img
                src="/imagenes/codigovestimenta.png"
                alt="Código de vestimenta"
                class="w-20 sm:w-24 object-contain"
                style="filter: brightness(0) saturate(100%) invert(72%) sepia(40%) saturate(400%) hue-rotate(5deg) brightness(95%);"
            />
        </div>

        <!-- TÍTULO "VESTIMENTA" -->
        <div class="flex items-center justify-center mb-2" id="titulo-vestimenta">
            <h2 class="font-jane-light uppercase tracking-[0.18em] text-[#d9c07a] text-lg sm:text-xl">
                Vestimenta
            </h2>
        </div>

        <!-- "Formal" -->
        <p class="font-sans font-normal text-[#f3ead9] text-lg sm:text-xl" id="tipo-vestimenta">
            Formal
        </p>

    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: "#seccion-vestimenta",
                start: "top 85%",
                toggleActions: "play none none reset",
            },
        });

        tl.fromTo(
            "#img-vestimenta",
            { opacity: 0, y: -20 },
            { opacity: 1, y: 0, duration: 0.9, ease: "power2.out" },
            0,
        )
        .fromTo(
            "#titulo-vestimenta",
            { opacity: 0, y: 20 },
            { opacity: 1, y: 0, duration: 0.9, ease: "power2.out" },
            0.2,
        )
        .fromTo(
            "#tipo-vestimenta",
            { opacity: 0, y: 15 },
            { opacity: 1, y: 0, duration: 0.8, ease: "sine.out" },
            0.4,
        )
        .fromTo(
            "#costadito-vestimenta",
            { opacity: 0, x: 40 },
            { opacity: 1, x: 0, duration: 1.2, ease: "power2.out" },
            0.2,
        );
    });
</script>
