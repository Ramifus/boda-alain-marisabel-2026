---
// DireccionCeremonia.astro
---

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- ⛪ SECCIÓN: CEREMONIA RELIGIOSA                              -->
<!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-8 pb-12 px-6 overflow-hidden" id="seccion-ceremonia">

    <!-- PLUMA SUPERIOR CENTRADA -->
    <div class="flex justify-center mb-6" id="pluma-ceremonia">
        <img
            src="/imagenes/pluma.png"
            alt="Pluma decorativa"
            class="w-24 sm:w-28 object-contain"
        />
    </div>

    <!-- COSTADITO2 IZQUIERDA (grande, absoluto) -->
    <img
        src="/imagenes/costadito2.png"
        alt="Decoración floral"
        class="absolute left-0 top-[15%] w-20 sm:w-24 z-10 pointer-events-none select-none"
        id="costadito2-ceremonia"
    />

    <!-- CONTENIDO CENTRADO -->
    <div class="relative z-20 flex flex-col items-center text-center max-w-xs mx-auto">

        <!-- ÍCONO IGLESIA -->
        <div class="mb-4" id="icono-ceremonia">
            <img
                src="/imagenes/recepcion.png"
                alt="Recepción"
                class="w-14 h-14 object-contain"
                style="filter: brightness(0) saturate(100%) invert(72%) sepia(40%) saturate(400%) hue-rotate(5deg) brightness(95%);"
            />
        </div>

        <!-- TÍTULO -->
        <h2
            class="font-jane-light uppercase tracking-[0.18em] text-[#d9c07a] text-lg sm:text-xl mb-8"
            id="titulo-ceremonia"
        >
            Ceremonia y Recepción
        </h2>

        <!-- FILA: HORA | SEPARADOR | LUGAR -->
        <div class="flex items-center justify-center gap-4 w-full mb-8" id="info-ceremonia">
            <!-- HORA -->
            <div class="text-left">
                <p class="font-mb-deco text-[#f3ead9] text-4xl sm:text-5xl leading-none">
                    14:30
                </p>
                <p class="font-sans text-[#d9c07a] text-lg uppercase tracking-widest mt-1">
                    pm
                </p>
            </div>

            <!-- LÍNEA VERTICAL -->
            <div class="w-px h-14 bg-[#C2A96B]/70"></div>

            <!-- LUGAR -->
            <div class="text-left">
                <p class="font-sans text-[#f3ead9] text-lg sm:text-xl leading-snug font-medium">
                    Casa Jardín
                </p>
                <p class="font-sans text-[#f3ead9]/80 text-base sm:text-lg leading-snug mt-1">
                    Av. Chilimarca, Tiquipaya<br />Cochabamba
                </p>
            </div>
        </div>

        <!-- BOTÓN VER UBICACIÓN -->
        <a
            href="https://maps.app.goo.gl/NQ48rMrJV9kfE8968"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-10 py-3 rounded-xl
                   bg-gradient-to-b from-[#e08344] to-[#c95f28] text-white
                   font-jane-light text-base uppercase tracking-[0.2em]
                   border border-[#f3ead9]/20 shadow-lg
                   transition-all duration-300 hover:scale-105 active:scale-95"
            id="btn-ubicacion"
        >
            Ver Ubicación
        </a>

    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: "#seccion-ceremonia",
                start: "top 85%",
                toggleActions: "play none none reset",
            },
        });

        tl.fromTo(
            "#pluma-ceremonia",
            { opacity: 0, y: -30, scale: 0.8 },
            { opacity: 1, y: 0, scale: 1, duration: 1, ease: "power2.out" },
            0,
        )
        .fromTo(
            "#costadito2-ceremonia",
            { opacity: 0, x: -40 },
            { opacity: 1, x: 0, duration: 1.2, ease: "power2.out" },
            0.2,
        )
        .fromTo(
            ["#icono-ceremonia", "#titulo-ceremonia", "#info-ceremonia", "#btn-ubicacion"],
            { opacity: 0, y: 25 },
            { opacity: 1, y: 0, duration: 0.9, stagger: 0.15, ease: "sine.out" },
            0.3,
        );
    });
</script>
